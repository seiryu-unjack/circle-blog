{"id":8,"date":"2025-03-08T20:24:02","date_gmt":"2025-03-08T11:24:02","guid":{"rendered":"https:\/\/circle.flexi.blue\/?page_id=8"},"modified":"2025-11-19T21:17:32","modified_gmt":"2025-11-19T12:17:32","slug":"home","status":"publish","type":"page","link":"https:\/\/circle.flexi.blue\/","title":{"rendered":"Home"},"content":{"rendered":"<h2>\u3053\u306e\u30b5\u30a4\u30c8\u306b\u3064\u3044\u3066<\/h2>\n<p class=\"font_8 wixui-rich-text__text\"><span class=\"color_36 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u3053\u306e\u30b5\u30a4\u30c8\u306f\u3001LED\u7dcf\u5408\u30b5\u30fc\u30af\u30eb\u300cFlexiblue\u300d\u306e\u3054\u6848\u5185\u30fb\u30b3\u30f3\u30c6\u30f3\u30c4\u30fb\u60c5\u5831\u304a\u3088\u3073<\/span><\/span><span class=\"color_36 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5e83\u5831\u3092\u76ee\u7684\u3068\u3057\u305f\u30b5\u30a4\u30c8\u3067\u3059\u3002<\/span><\/span><\/p>\n<p class=\"font_8 wixui-rich-text__text\"><a href=\"https:\/\/circle.flexi.blue\/terms\/\" title=\"\u5229\u7528\u898f\u7d04\"><span class=\"color_36 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u200b<\/span><\/span><\/a><span class=\"color_36 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\"><a href=\"https:\/\/circle.flexi.blue\/terms\/\" title=\"\u5229\u7528\u898f\u7d04\">\u5229\u7528\u898f\u7d04<\/a>\u3092\u304a\u8aad\u307f\u306e\u3046\u3048\u3001\u4e0a\u306e\u30e1\u30cb\u30e5\u30fc\u3088\u308a\u5404\u30b3\u30f3\u30c6\u30f3\u30c4\u3078\u304a\u9032\u307f\u304f\u3060\u3055\u3044\u3002<\/span><\/span><\/p>\n<p>&nbsp;<\/p>\n<h2>\u304a\u77e5\u3089\u305b\u30fb\u66f4\u65b0\u60c5\u5831\u7b49\u306e\u3054\u6848\u5185<\/h2>\n<p>2025.11.14\u3000\u51fa\u5c55\u60c5\u5831\u66f4\u65b0\uff08ISF15\u306e\u3054\u6848\u5185\u4e8b\u9805\u63b2\u8f09\u3057\u307e\u3057\u305f\uff09<\/p>\n<p>2025.4.24\u3000\u51fa\u5c55\u60c5\u5831\u66f4\u65b0\u304a\u3088\u3073\u4ed6\u30da\u30fc\u30b8\u6574\u5099\u7b49\uff08\u5236\u4f5c\u958b\u59cb\u304b\u3089\u306e\u9593\u306b\u9806\u6b21\u9032\u3081\u307e\u3057\u305f\uff09<\/p>\n<p>2025.3.8\u3000\u30db\u30fc\u30e0\u30da\u30fc\u30b8\u5236\u4f5c\u958b\u59cb<\/p>\n<hr \/>\n<p>\u3010\u304a\u8a6b\u3073\u3011<\/p>\n<p>\u300cLED\u3067\u4f5c\u308b\u30a2\u30a4\u30de\u30b9\u306e\u4e16\u754c\u25c7\u5165\u9580\u7de8\u25c7\u300d\u304c\u958b\u3051\u306a\u3044\u4e0d\u5177\u5408\u306b\u3064\u3044\u3066\u306e\u5831\u544a\uff082025.11.19\uff09<\/p>\n<p>\u5148\u65e5\u306eISF15\u306b\u304a\u3044\u3066\u3001\u300cLED\u3067\u4f5c\u308b\u30a2\u30a4\u30de\u30b9\u306e\u4e16\u754c\u25c7\u5165\u9580\u7de8\u25c7\u300d\u3092\u9812\u5e03\u3057\u307e\u3057\u305f\u304c\u3001\u30d5\u30a1\u30a4\u30eb\u304c\u958b\u3051\u306a\u3044\u7533\u3057\u51fa\u304c2\u4ef6\u3042\u308a\u307e\u3057\u305f\u3002<\/p>\n<p>\u3053\u308c\u306b\u4f34\u3044\u3001\u8abf\u67fb\u3044\u305f\u3057\u307e\u3057\u305f\u3068\u3053\u308d\u3001\u4f5c\u696d\u6642\u306b\u304a\u3051\u308b\u30b5\u30fc\u30af\u30eb\u8cac\u4efb\u8005\u306e\u30df\u30b9\u306b\u3088\u308a\u30d5\u30a1\u30a4\u30eb\u304c\u958b\u3051\u306a\u3044\u3053\u3068\u304c\u5224\u660e\u3057\u307e\u3057\u305f\u3002\u307e\u305f\u3001\u3055\u3089\u306b\u8ffd\u52a0\u8abf\u67fb\u3092\u884c\u3044\u307e\u3057\u305f\u3068\u3053\u308d\u3001ISF14\u306b\u304a\u3044\u3066\u3082\u540c\u69d8\u306e\u4e8b\u8c61\u306e\u7591\u3044\u304c\u3042\u3063\u305f\u3053\u3068\u304c\u767a\u899a\u3057\u307e\u3057\u305f\u3002\uff082025\u5e745\u6708\u306eMBF16\u4ee5\u524d\u306f\u4e0d\u5177\u5408\u304c\u306a\u3044\u3053\u3068\u3092\u78ba\u8a8d\u3057\u3066\u304a\u308a\u307e\u3059\uff09<\/p>\n<p>\u3054\u8cfc\u5165\u3044\u305f\u3060\u3044\u305f\u7686\u69d8\u306b\u306f\u5927\u5909\u3054\u8ff7\u60d1\u3092\u304a\u304b\u3051\u3057\u3001\u8aa0\u306b\u7533\u3057\u8a33\u3054\u3056\u3044\u307e\u305b\u3093\u3002<\/p>\n<p><strong>\uff1c\u5bfe\u8c61\u3068\u306a\u308b\u9812\u5e03\u54c1\uff1e<\/strong><\/p>\n<ul>\n<li>\u300cLED\u3067\u4f5c\u308b\u30a2\u30a4\u30de\u30b9\u306e\u4e16\u754c\u25c7\u5165\u9580\u7de8\u25c7\u300d\uff08ISF14\u9812\u5e03\u52061\u4ef6\u3001ISF15\u9812\u5e03\u52064\u4ef6\uff09<\/li>\n<\/ul>\n<p>\u203b\u3059\u3067\u306b2\u4ef6\u306e\u304a\u554f\u3044\u5408\u308f\u305b\u304c\u3042\u308a\u307e\u3057\u305f\u304c\u3001\u6b8b\u308a3\u4ef6\u306f\u73fe\u72b6\u628a\u63e1\u3067\u304d\u3066\u3044\u306a\u3044\u72b6\u614b\u3067\u3059\u3002\u3064\u304d\u307e\u3057\u3066\u306f\u3001\u3054\u8cfc\u5165\u6642\u306b\u304a\u6e21\u3057\u3057\u305f\u7d19\u306b\u3042\u308a\u307e\u3059\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u3082\u3057\u304f\u306f\u30b5\u30fc\u30af\u30eb\u8cac\u4efb\u8005\u306b\u9023\u7d61\u3067\u304d\u308b\u4ed6\u306e\u624b\u6bb5\uff08SNS\u7b49\uff09\u304c\u3054\u3056\u3044\u307e\u3057\u305f\u3089\u3001\u305d\u3061\u3089\u306b\u3054\u4e00\u5831\u3044\u305f\u3060\u3051\u308b\u3068\u5e78\u3044\u3067\u3059\u3002<\/p>\n<p><strong>\uff1c\u4eca\u5f8c\u306e\u5bfe\u5fdc\uff1e<\/strong><\/p>\n<p>\u307e\u305a\u3001\u672c\u6765\u306e\u9812\u5e03\u54c1\u3092\u518d\u5ea6\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u3057\u3001\u304a\u554f\u3044\u5408\u308f\u305b\u3044\u305f\u3060\u304d\u307e\u3057\u305f\u65b9\u304b\u3089\u9806\u6b21\u3001\u30e1\u30fc\u30eb\u7b49\u306b\u3066\u518d\u5ea6\u3054\u6848\u5185\u3044\u305f\u3057\u307e\u3059\u3002<\/p>\n<p>\u306a\u304a\u3001\u4eca\u56de\u306f\u660e\u3089\u304b\u306b\u30b5\u30fc\u30af\u30eb\u8cac\u4efb\u8005\u306b\u3088\u308b\u904e\u5931\u6848\u4ef6\u3068\u306a\u308a\u307e\u3059\u306e\u3067\u3001\u5bfe\u8c61\u306e\u65b9\u306b\u3064\u304d\u307e\u3057\u3066\u306f\u3001\u304a\u8a6b\u3073\u4ee3\u308f\u308a\u306e\u30af\u30fc\u30dd\u30f3\u3092\u4ed8\u4e0e\u3055\u305b\u3066\u3044\u305f\u3060\u304d\u307e\u3059\uff08\u8a73\u7d30\u306f\u5225\u9014\u304a\u4f1d\u3048\u3057\u307e\u3059\uff09\u300211\/24\u307e\u3067\u306b\u306f\u521d\u671f\u5bfe\u5fdc\u3092\u5b8c\u4e86\u3055\u305b\u3066\u3044\u305f\u3060\u304f\u6240\u5b58\u3067\u3054\u3056\u3044\u307e\u3059\u306e\u3067\u3001\u6050\u308c\u5165\u308a\u307e\u3059\u304c\u3082\u3046\u5c11\u3005\u304a\u5f85\u3061\u304f\u3060\u3055\u3044\u3002<\/p>\n<p>\u307e\u305f\u3001\u307e\u3060\u3054\u4e00\u5831\u3044\u305f\u3060\u3044\u3066\u3044\u307e\u305b\u3093\u65b9\u306b\u3064\u304d\u307e\u3057\u3066\u306f\u3001\u304a\u624b\u6570\u3067\u306f\u3054\u3056\u3044\u307e\u3059\u304c\u3001\u3054\u4e00\u5831\u3044\u305f\u3060\u304d\u307e\u3057\u305f\u3089\u4e0a\u8ff0\u306e\u5bfe\u5fdc\u3092\u3055\u305b\u3066\u3044\u305f\u3060\u304d\u307e\u3059\u306e\u3067\u3001\u304a\u7533\u3057\u51fa\u3044\u305f\u3060\u3051\u308b\u3068\u5e78\u3044\u3067\u3059\u3002<\/p>\n<p>\u3053\u306e\u5ea6\u306f\u5927\u5909\u3054\u8ff7\u60d1\u3092\u304a\u304b\u3051\u3044\u305f\u3057\u307e\u3057\u305f\u3053\u3068\u3092\u304a\u8a6b\u3073\u7533\u3057\u4e0a\u3052\u307e\u3059\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u3053\u306e\u30b5\u30a4\u30c8\u306b\u3064\u3044\u3066 \u3053\u306e\u30b5\u30a4\u30c8\u306f\u3001LED\u7dcf\u5408\u30b5\u30fc\u30af\u30eb\u300cFlexiblue\u300d\u306e\u3054\u6848\u5185\u30fb\u30b3\u30f3\u30c6\u30f3\u30c4\u30fb\u60c5\u5831\u304a\u3088\u3073\u5e83\u5831\u3092\u76ee\u7684\u3068\u3057\u305f\u30b5\u30a4\u30c8\u3067\u3059\u3002 \u200b\u5229\u7528\u898f\u7d04\u3092\u304a\u8aad\u307f\u306e\u3046\u3048\u3001\u4e0a\u306e\u30e1\u30cb\u30e5\u30fc\u3088\u308a\u5404\u30b3\u30f3\u30c6\u30f3\u30c4\u3078\u304a\u9032\u307f\u304f\u3060\u3055\u3044\u3002 &#038;nbsp\u2026<\/p>\n","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"_import_markdown_pro_load_document_selector":0,"_import_markdown_pro_submit_text_textarea":"","footnotes":""},"class_list":["post-8","page","type-page","status-publish","hentry"],"aioseo_notices":[],"_links":{"self":[{"href":"https:\/\/circle.flexi.blue\/wp-json\/wp\/v2\/pages\/8","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/circle.flexi.blue\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/circle.flexi.blue\/wp-json\/wp\/v2\/types\/page"}],"author":[{"em