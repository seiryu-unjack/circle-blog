652f\u6255\u306b\u3064\u3044\u3066\uff1e<\/strong><\/p>\n<p>\u306a\u304a\u3001\u9812\u5e03\u7269\u306e\u652f\u6255\u306f\u3044\u3064\u3082\u306e\u3054\u3068\u304f<span style=\"color: #00ffff;\"><strong>\u300c\u30ad\u30e3\u30c3\u30b7\u30e5\u30ec\u30b9\u652f\u6255\u300d<\/strong><\/span>\u3082\u5bfe\u5fdc\u3057\u3066\u304a\u308a\u307e\u3059\u3002<span style=\"text-decoration: underline;\"><span style=\"color: #ff0000; text-decoration: underline;\">\u30a2\u30a4\u30de\u30b9\u95a2\u4fc2\u306e\u30b5\u30fc\u30af\u30eb\u3067\u306f\u6570\u5c11\u306a\u3044\u30ad\u30e3\u30c3\u30b7\u30e5\u30ec\u30b9\u6c7a\u6e08\u5bfe\u5fdc\u30b5\u30fc\u30af\u30eb\u3067\u3059\u3002<\/span><\/span>\u624b\u6301\u3061\u306e\u73fe\u91d1\u306b\u7e1b\u3089\u308c\u308b\u3053\u3068\u306a\u304f\u3001\u5f0a\u30b5\u30fc\u30af\u30eb\u306e\u9812\u5e03\u7269\u3092\u30af\u30ec\u30b8\u30c3\u30c8\u6c7a\u6e08\u30fbIC\u30ab\u30fc\u30c9\u6c7a\u6e08\u304a\u3088\u3073QR\u30b3\u30fc\u30c9\u6c7a\u6e08\u3067\u5bfe\u5fdc\u3044\u305f\u3060\u304f\u3053\u3068\u304c\u53ef\u80fd\u3067\u3059\u3002\u5f0a\u30b5\u30fc\u30af\u30eb\u3067\u30ad\u30e3\u30c3\u30b7\u30e5\u30ec\u30b9\u6c7a\u6e08\u3057\u3066\u3001\u6d6e\u3044\u305f\u73fe\u91d1\u306f\u4ed6\u306e\u6c17\u306b\u306a\u308b\u30b5\u30fc\u30af\u30eb\u69d8\u306e\u9812\u5e03\u7269\u8cfc\u5165\u306b\u3054\u5229\u7528\u304f\u3060\u3055\u3044\uff01<\/p>\n<p>\u4f7f\u3048\u308b\u30d6\u30e9\u30f3\u30c9\u306f\u3001\u4e0a\u8ff0\u306e\u753b\u50cf\u306e\u901a\u308a\u3067\u3059\u3002<span style=\"color: #ff0000;\"><strong>UnionPay\uff08\u9280\u806f\uff09\u306e\u3054\u5229\u7528\u304c\u53ef\u80fd\u306b\u306a\u308a\u307e\u3057\u305f\uff01<\/strong><\/span><\/p>\n<p>\u307e\u305f\u3001<span style=\"color: #ff0000;\"><strong>QR\u30b3\u30fc\u30c9\u6c7a\u6e08\u306b\u3064\u304d\u307e\u3057\u3066\u3082\u4ee5\u4e0b\u306e\u30d6\u30e9\u30f3\u30c9\u306e\u3054\u5229\u7528\u304c\u53ef\u80fd\u306b\u306a\u308a\u307e\u3057\u305f\u3002<\/strong><\/span><\/p>\n<ul>\n<li>\uff44\u6255\u3044<\/li>\n<li>auPay<\/li>\n<li>\u30e1\u30eb\u30da\u30a4<\/li>\n<li>Wechat Pay<\/li>\n<li>Alipay+<\/li>\n<\/ul>\n<p>\u203b\u4eca\u56de\u3001\u697d\u5929Pay\u306f\u5be9\u67fb\u7d99\u7d9a\u4e2d\u306b\u3064\u304d\u3001\u3054\u5229\u7528\u306b\u306a\u308c\u307e\u305b\u3093\u3002<\/p>\n<p>\u3088\u308a\u4fbf\u5229\u306b\u306a\u3063\u305f\u5f0a\u30b5\u30fc\u30af\u30eb\u3078\u306e\u304a\u8d8a\u3057\u3092\u5fc3\u3088\u308a\u304a\u8a6b\u3073\u7533\u3057\u4e0a\u3052\u307e\u3059\u3002<\/p>\n<p><strong>\uff1c\u30df\u30cb\u30d3\u30b8\u30e7\u30f3\u306e\u8868\u793a\u5185\u5bb9\u306b\u3064\u3044\u3066\uff1e<\/strong><\/p>\n<p>\u4eca\u56de\u306f\u3001\u6765\u308b2026\u5e743\u6708\u306b\u884c\u308f\u308c\u308b\u300cTHE IDOLM@STER MILLION LIVE! 11thLIVE\u300d\u306e\u51fa\u6f14\u30a2\u30a4\u30c9\u30eb\u975e\u516c\u5f0f\u30c7\u30e2\u30e0\u30fc\u30d3\u30fc\u3092\u62ab\u9732\u3059\u308b\u4e88\u5b9a\u3067\u3059\u3002<\/p>\n<p><strong>\uff1c\u534a\u56fa\u5b9a\u30e6\u30cb\u30c3\u30c8\u306e\u8868\u793a\u5185\u5bb9\u306b\u3064\u3044\u3066\uff1e<\/strong><\/p>\n<p>\u4eca\u56de\u306f\u3001\u4eca\u6708\u521d\u3081\u306e\u30df\u30ea\u30d1\u30e9\u3068\u540c\u69d8\u3001\u5148\u65e5\u306e\u30df\u30ea\u30b7\u30bf8\u5468\u5e74\u8a18\u5ff5\u306e\u30a2\u30fc\u30c8\u30b3\u30f3\u30c6\u30b9\u30c8\u3067\u7279\u5225\u8cde\u3092\u53d7\u8cde\u3057\u305f\u969b\u306e\u8868\u793a\u3092\u518d\u73fe\u3057\u307e\u3059\u3002<\/p>\n<p>\u306a\u304a\u3001\u4f75\u50ac\u306e\u30b7\u30e3\u30cb\u30de\u30b9\u30fb\u5b66\u30de\u30b9\u30fb\u30c7\u30ec\u30de\u30b9\u306e\u8868\u793a\u3082\u51fa\u305d\u3046\u3068\u601d\u3048\u3070\u51fa\u305b\u307e\u3059\u3002\uff08\u305d\u306e\u65e5\u306e\u6c17\u5206\u6b21\u7b2c\uff09<\/p>\n<p>\u203b\u30ea\u30af\u30a8\u30b9\u30c8\u306f\u539f\u5247\u3068\u3057\u3066\u3067\u304d\u307e\u305b\u3093\u3002\u3054\u4e86\u627f\u304f\u3060\u3055\u3044\u3002<\/p>\n<ul><\/ul>\n<p><strong>\uff1cLED\u8868\u793a\u306e\u64ae\u5f71\u306b\u3064\u3044\u3066\uff1e<\/strong><\/p>\n<p>\u6b4c\u59eb\u5ead\u5712\u306e\u30ec\u30ae\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u306e\u95a2\u4fc2\u4e0a\u3001\u30b3\u30b9\u30d7\u30ec\u64ae\u5f71\u4ee5\u5916\u306f\u7121\u6599\u3068\u306a\u3063\u3066\u304a\u308a\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u52d5\u753b\u64ae\u5f71\u306f\u3054\u9060\u616e\u304f\u3060\u3055\u3044\u3002\u307e\u305f\u3001\u5f53\u65e5\u306e\u64ae\u5f71\u5834\u6240\u3001\u6df7\u96d1\u72b6\u6cc1\u306b\u3088\u3063\u3066\u3001\u64ae\u5f71\u6a5f\u6750\u4f7f\u7528\u306e\u5236\u9650\uff08\u4e09\u811a\u3001\u30d5\u30e9\u30c3\u30b7\u30e5\u898f\u5236\u3001\u305d\u306e\u4ed6\uff09\u3092\u304b\u3051\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002\u305d\u306e\u4ed6\u5f53\u65e5\u306e\u6b4c\u59eb\u5ead\u5712\u306e\u30b9\u30bf\u30c3\u30d5\u306e\u6307\u793a\u306b\u5f93\u3063\u3066\u304f\u3060\u3055\u3044\u3002<\/p>\n<p>\u305d\u306e\u969b\u306f\u3001\u4ee5\u4e0b\u306b\u5341\u5206\u914d\u616e\u3057\u3066\u304f\u3060\u3055\u3044\u3002<\/p>\n<ul>\n<li>\u5bfe\u7269\u64ae\u5f71\u306e\u7bc4\u56f2\u306f\u3001\u30df\u30cb\u30d3\u30b8\u30e7\u30f3\u30fb\u534a\u56fa\u5b9a\u542b\u3081LED\u8868\u793a\u306e\u307f\u3068\u3055\u305b\u3066\u3044\u305f\u3060\u304d\u307e\u3059\u3002\uff08\u30b9\u30da\u30fc\u30b9\u5168\u666f\u30fb\u4f1a\u5834\u5185\u98a8\u666f\u30fb\u52d5\u753b\u64ae\u5f71\u30fb\u30d5\u30e9\u30c3\u30b7\u30e5\u64ae\u5f71\u30fb\u914d\u4fe1\u30fb\u7b2c\u4e09\u8005\u3092\u5199\u3059\u884c\u70ba\u7b49\u306f\u3054\u9060\u616e\u9858\u3044\u307e\u3059\u3002\u307e\u305f\u3001SNS\u7b49\u3078\u306e\u30a2\u30c3\u30d7\u3082\u5408\u308f\u305b\u3066\u3054\u9060\u616e\u9858\u3044\u307e\u3059\u3002\uff09<\/li>\n<li>\u4e0a\u8ff0\u306eSNS\u7b49\u306e\u30a2\u30c3\u30d7\u306f\u3001Twitter\uff08X\uff09\u30fbFacrbook\u30fbInstagram\u30fbMisskey\u7b49\u306e\u5404SNS\u3092\u306f\u3058\u3081\u3001LINE\u3084Discord\u7b49\u3082\u542b\u307e\u308c\u307e\u3059\u3002<\/li>\n<li>\u4e0a\u8ff0\u306b\u969b\u3057\u3066\u3001\u539f\u5247\u3068\u3057\u3066\u7121\u65ad\u3067\u306e\u64ae\u5f71\u306f\u304a\u65ad\u308a\u7533\u3057\u4e0a\u3052\u307e\u3059\u300