{"id":134,"date":"2025-04-10T23:30:01","date_gmt":"2025-04-10T14:30:01","guid":{"rendered":"https:\/\/circle.flexi.blue\/?page_id=134"},"modified":"2025-04-10T23:30:01","modified_gmt":"2025-04-10T14:30:01","slug":"terms","status":"publish","type":"page","link":"https:\/\/circle.flexi.blue\/terms\/","title":{"rendered":"\u5229\u7528\u898f\u7d04"},"content":{"rendered":"<h2><span>\u200b\u3054\u5229\u7528\u306b\u3042\u305f\u3063\u3066<\/span><\/h2>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u306e\u5229\u7528\u898f\u7d04\u306f\u65e5\u672c\u56fd\u306b\u304a\u3051\u308b\u6cd5\u5f8b\u7b49\u5168\u822c\u306b\u6e96\u62e0\u3057\u3001\u305d\u308c\u5f93\u3063\u3066\u89e3\u91c8\u3055\u308c\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u306e\u3054\u5229\u7528\u306b\u3088\u3063\u3066\u5229\u7528\u8005\u306f\u5229\u7528\u898f\u7d04\u306b\u540c\u610f\u3057\u305f\u3082\u306e\u3068\u307f\u306a\u3057\u3001\u9055\u53cd\u3057\u305f\u5834\u5408\u306f\u8b66\u5bdf\u30fb\u53f8\u6cd5\u6a5f\u95a2\u7b49\u306e\u5404\u7a2e\u6a5f\u95a2\u3092\u901a\u3057\u3066\u554f\u984c\u3092\u89e3\u6c7a\u3059\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u306e\u5229\u7528\u898f\u7d04\u306f\u7ba1\u7406\u8005\u306b\u3088\u3063\u3066\u4e88\u544a\u306a\u304f\u5909\u66f4\u3055\u308c\u308b\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002\u305d\u306e\u5834\u5408\u3001\u5909\u66f4\u3057\u305f\u6642\u70b9\u3088\u308a\u65b0\u898f\u7d04\u304c\u9069\u7528\u3055\u308c\u305f\u3082\u306e\u3068\u307f\u306a\u3057\u307e\u3059\u3002<\/span><\/p>\n<h3 class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\"><span class=\"wixGuard wixui-rich-text__text\">\u200b\u8457\u4f5c\u6a29\u306b\u3064\u3044\u3066<\/span><\/span><\/h3>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u5185\u306e\u30d5\u30a1\u30a4\u30eb\u30fb\u753b\u50cf\u30fb\u52d5\u753b\u7b49\u306e\u8457\u4f5c\u6a29\u306f\u3001\u5168\u3066\u7ba1\u7406\u8005\u306b\u5e30\u5c5e\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u65e5\u672c\u56fd\u306b\u304a\u3051\u308b\u6cd5\u5f8b\u7b49\u5168\u822c\u306b\u6e96\u62e0\u3057\u305f\u79c1\u7684\u5229\u7528\u3092\u9664\u304d\u3001\u5f53\u30b5\u30a4\u30c8\u5185\u306e\u30d5\u30a1\u30a4\u30eb\u30fb\u753b\u50cf\u30fb\u52d5\u753b\u7b49\u30b3\u30f3\u30c6\u30f3\u30c4\u306e\u7121\u65ad\u4f7f\u7528\u3092\u7981\u6b62\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u307e\u305f\u3001\u30a4\u30d9\u30f3\u30c8\u7b49\u306b\u304a\u3051\u308bLED\u8868\u793a\u7b49\u306e\u64ae\u5f71\u306b\u3064\u3044\u3066\u306f\u30a4\u30d9\u30f3\u30c8\u7b49\u3067\u8a2d\u5b9a\u3055\u308c\u3066\u3044\u308b\u30eb\u30fc\u30eb\u30fb\u30ec\u30ae\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u306b\u6e96\u62e0\u3057\u305f\u3046\u3048\u3067\u304a\u9858\u3044\u3057\u307e\u3059\u3002\u306a\u304a\u3001SNS\u3078\u306e\u516c\u958b\u306b\u95a2\u3057\u3066\u3082\u540c\u69d8\u3068\u306a\u308a\u307e\u3059\u3002\u7279\u306b\u30eb\u30fc\u30eb\u3084\u30ec\u30ae\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u3067\u5236\u9650\u304c\u306a\u3044\u5834\u5408\u306f\u3001SNS\u6295\u7a3f\u3057\u3066\u3044\u305f\u3060\u3044\u3066\u3082\u5dee\u3057\u652f\u3048\u306f\u3054\u3056\u3044\u307e\u305b\u3093\u3002<\/span><\/p>\n<p>\u305f\u3060\u3057\u3001<span style=\"color: #ff0000;\">\u6b63\u5f53\u306a\u7406\u7531\u306a\u304f\u3001\u865a\u507d\u767a\u8a00\uff08\u4f8b\uff1a\u5f0a\u30b5\u30fc\u30af\u30eb\u306e<\/span><span class=\"wixui-rich-text__text\"><span style=\"color: #ff0000;\">LED\u8868\u793a\u3092\u64ae\u5f71\u3057\u3066\u81ea\u4f5c\u767a\u8a00\u3059\u308b\u7b49\uff09\u304a\u3088\u3073\u6839\u62e0\u306a\u304d\u8ab9\u8b17\u4e2d\u50b7\u30fb\u6a29\u5229\u4fb5\u5bb3\u7b49\u306f\u53b3\u306b\u614e\u3093\u3067\u3044\u305f\u3060\u304f\u3088\u3046\u304a\u9858\u3044\u7533\u3057\u4e0a\u3052\u307e\u3059\u3002<\/span>\u60aa\u8cea\u306a\u5834\u5408\u306f\u3001\u8b66\u5bdf\u30fb\u53f8\u6cd5\u6a5f\u95a2\u7b49\u306e\u5404\u7a2e\u6a5f\u95a2\u3092\u901a\u3057\u3066\u554f\u984c\u3092\u89e3\u6c7a\u3059\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u6b63\u5f53\u306a\u7406\u7531\u3092\u3082\u3063\u3066\u30d5\u30a1\u30a4\u30eb\u30fb\u753b\u50cf\u30fb\u52d5\u753b\u7b49\u306e\u5f15\u7528\u3092\u5e0c\u671b\u3055\u308c\u308b\u5834\u5408\u3001\u9812\u5e03\u7269\u3092\u5229\u7528\u3057\u305f\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8\u30fb\u52d5\u753b\u3092<\/span><span class=\"wixui-rich-text__text\">\u56e3\u4f53<\/span><span class=\"wixui-rich-text__text\">\u307e\u305f\u306f\u55b6\u5229\u76ee\u7684\u306e\u30db\u30fc\u30e0\u30da\u30fc\u30b8\u7b49\u306b\u304a\u3044\u3066\u516c\u306b\u63b2\u8f09\u3059\u308b\u5834\u5408\u3001\u5fc5\u305a\u4e0b\u8a18\u554f\u3044\u5408\u308f\u305b\u5148\u3078\u3054\u9023\u7d61\u304f\u3060\u3055\u3044\u3002<\/span><span class=\"wixui-rich-text__text\">\u305f\u3060\u3057\u3001\u4e8b\u7531\u306b\u3088\u308a\u8a31\u53ef\u3067\u304d\u306a\u3044\u5834\u5408\u3082\u3054\u3056\u3044\u307e\u3059\u306e\u3067\u3001\u3042\u3089\u304b\u3058\u3081\u3054\u4e86\u627f\u304f\u3060\u3055\u3044\u3002<\/span><\/p>\n<h3 class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\"><span class=\"wixGuard wixui-rich-text__text\">\u96fb\u5b50\u30b3\u30f3\u30c6\u30f3\u30c4\u306e\u53d6\u308a\u6271\u3044\u306b\u3064\u3044\u3066<\/span><\/span><\/h3>\n<p>\u3054\u8cfc\u5165\u3044\u305f\u3060\u3044\u305f\u96fb\u5b50\u30b3\u30f3\u30c6\u30f3\u30c4\u306f\u8cfc\u5165\u8005\u306e\u307f\u53d6\u308a\u6271\u3044\u304c\u3067\u304d\u307e\u3059\u3002\u3057\u305f\u304c\u3063\u3066\u3001<span style=\"color: #ff0000;\"><strong>\u8cfc\u5165\u8005\u672c\u4eba\u4ee5\u5916\u306e\u4f7f\u7528\u304a\u3088\u3073\u8a31\u53ef\u306a\u304d\u8b72\u6e21\u306f\u7981\u6b62\u3044\u305f\u3057\u307e\u3059\u3002<\/strong><\/span>\uff08\u4eba\u6570\u5206\u304a\u8cb7\u3044\u6c42\u3081\u3044\u305f\u3060\u3044\u305f\u5834\u5408\u306f\u9664\u304d\u307e\u3059\uff09<\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u306a\u304a\u3001\u9812\u5e03\u3057\u305f\u96fb\u5b50\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u3064\u3044\u3066\u306f\u3001\u3059\u3079\u3066\u5f0a\u30b5\u30fc\u30af\u30eb\u306b\u8457\u4f5c\u6a29\u304c\u3042\u308a\u3001<span style=\"color: #ff0000;\">\u5f0a\u30b5\u30fc\u30af\u30eb\u306e\u8a31\u53ef\u306a\u304f\u5f15\u7528\u30fb\u4ed6\u8005\u3078\u306e\u8b72\u6e21\u30fb\u30b3\u30f3\u30c6\u30f3\u30c4\u306e\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u304a\u3088\u3073\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8\u3092\u64ae\u5f71\u3057\u3066\u8ab0\u3082\u304c\u898b\u3089\u308c\u308b\u72b6\u614b\u306b\u3059\u308b\u306a\u3069\u306e\u884c\u70ba\u306f\u7981\u6b62\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u307e\u305f\u3001<span style=\"color: #ff0000;\">\u540c\u69d8\u306b\u30d1\u30b9\u30ef\u30fc\u30c9\u3092\u4ed6\u4eba\u306b\u6559\u3048\u308b\u3053\u3068\u3084\u3001\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u7528\u7d19\u306b\u8a18\u8f09\u3055\u308c\u3066\u3044\u308b\u60c5\u5831\u3092\u8cfc\u5165\u8005\u4ee5\u5916\u306b\u6559\u3048\u308b\u884c\u70ba\u306a\u3069\u306e<strong>\u5f0a\u30b5\u30fc\u30af\u30eb\u306b\u5bfe\u3057\u3066\u640d\u5bb3\u3092\u4e0e\u3048\u308b\u884c\u70ba\u3082\u7981\u6b62<\/strong>\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u4e0a\u8ff0\u306e\u884c\u70ba\u306f\u3001\u6a29\u5229\u4fb5\u5bb3\u306b\u5f53\u305f\u308a\u307e\u3059\u3002\u60aa\u8cea\u306a\u5834\u5408\u306f\u3001\u8b66\u5bdf\u30fb\u53f8\u6cd5\u6a5f\u95a2\u7b49\u306e\u5404\u7a2e\u6a5f\u95a2\u3092\u901a\u3057\u3066\u554f\u984c\u3092\u89e3\u6c7a\u3059\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixGuard wixui-rich-text__text\">\u200b<\/span><\/p>\n<h2>\u30ea\u30f3\u30af\u306b\u3064\u3044\u3066<\/h2>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u306f<span style=\"color: #ff0000;\"><strong>\u6761\u4ef6\u9650\u5b9a<\/strong><\/span>\u3067\u30ea\u30f3\u30af\u30d5\u30ea\u30fc\u3068\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u30c8\u30c3\u30d7\u30da\u30fc\u30b8\u3078\u306e\u30ea\u30f3\u30af\u306f\u3054\u81ea\u7531\u306b\u3057\u3066\u3044\u305f\u3060\u304f\u3053\u3068\u304c\u53ef\u80fd\u3067\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u305d\u306e\u969b\u3001\u30ea\u30f3\u30af\u5148\u306f<a href=\"https:\/\/circle.flexi.blue\/\" target=\"_blank\" class=\"wixui-rich-text__text\" rel=\"noopener\">https:\/\/circle.flexi.blue\/<\/a>\u3078\u304a\u9858\u3044\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u305d\u306e\u4ed6\u30da\u30fc\u30b8\u3078\u306e\u8a31\u53ef\u306a\u304d\u76f4\u30ea\u30f3\u30af\u306f\u3054\u9060\u616e\u304f\u3060\u3055\u3044<span class=\"color_36 wixui-rich-text__text\">\u3002\u307e\u305f\u3001\u96fb\u5b50\u30b3\u30f3\u30c6\u30f3\u30c4\u9812\u5e03\u7269\u306e<\/span>\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9URL\u3078\u306e\u76f4\u30ea\u30f3\u30af\u306f\u56fa\u304f\u304a\u65ad\u308a\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u3053\u306e\u307b\u304b\u3001\u55b6\u5229\u76ee\u7684\u30fb\u8ab9\u8b17\u4e2d\u50b7\u30fb\u6a29\u5229\u4fb5\u5bb3\u3084\u305d\u306e\u53ef\u80fd\u6027\u3092\u8a8d\u3081\u308b\u5834\u5408\u3001\u516c\u5e8f\u826f\u4fd7\u306b\u53cd\u3059\u308b\u7528\u6cd5\u3067\u306e\u30ea\u30f3\u30af\u306f\u304a\u65ad\u308a\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u4e0a\u8a18\u6761\u4ef6\u3092\u6e80\u305f\u3057\u305f\u3046\u3048\u3067\u3001\u30ea\u30f3\u30af\u3055\u308c\u308b\u969b\u306f\u4efb\u610f\u3067\u306f\u3054\u3056\u3044\u307e\u3059\u304c\u4e0b\u8a18\u554f\u3044\u5408\u308f\u305b\u5148\u307e\u3067\u3054\u4e00\u5831\u3044\u305f\u3060\u3051\u307e\u3057\u305f\u3089\u5e78\u3044\u3067\u3059\u3002<\/span><\/p>\n<p>&nbsp;<\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u306e\u95b2\u89a7\u3084\u30b5\u30a4\u30c8\u5185\u306e\u60c5\u5831\u306b\u3088\u3063\u3066\u767a\u751f\u3057\u305f\u640d\u5bb3\u7b49\u306b\u95a2\u3057\u3066\u3001\u5f53\u30b5\u30a4\u30c8\u304a\u3088\u3073\u7ba1\u7406\u4eba\u306f\u4e00\u5207\u306e\u8cac\u4efb\u3092\u8ca0\u3044\u304b\u306d\u307e\u3059\u3002<\/span><\/p>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\"><span class=\"wixGuard wixui-rich-text__text\">\u200b<\/span><\/span><\/p>\n<h2>\u514d\u8cac\u4e8b\u9805<\/h2>\n<p class=\"font_7 wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">\u5f53\u30b5\u30a4\u30c8\u306e\u30b3\u30f3\u30c6\u30f3\u30c4\u304a\u3088\u3073\u9812\u5e03\u7269\u7b49\u306b\u306f\u3001\u5834\u5408\u306b\u3088\u308a\u7279\u5b9a\u306e\u56e3\u4f53\u3084\u4f01\u696d\u306e\u5546\u6a19\u30fb\u30de\u30fc\u30af\u7b49\u304c\u542b\u307e\u308c\u3066\u3044\u308b\u5834\u5408\u304c\u3054\u3056\u3044\u307e\u3059\u304c\u3001<\/span><span class=\"wixui-rich-text__text\">\u5f53\u8a72\u56e3\u4f53\u30fb\u4f01\u696d\u3068\u5f53\u30b5\u30a4\u30c8\u306e\u9593\u306b\u306f\u7279\u8a18\u306e\u306a\u3044\u9650\u308a\u4e00\u5207\u306e\u95a2\u4fc2\u306f\u3054\u3056\u3044\u307e\u305b\u3093\u3002\u5f53\u8a72\u56e3\u4f53\u30fb\u4f01\u696d\u3078\u306e\u554f\u3044\u5408\u308f\u305b\u7b49\u306f\u304a\u3084\u3081\u304f\u3060\u3055\u3044\u3002<\/span><\/p>\n<p>&nbsp;<\/p>\n<h2>\u304a\u554f\u3044\u5408\u308f\u305b<\/h2>\n<p>\u5f53\u30b5\u30a4\u30c8\u304a\u3088\u3073\u9812\u5e03\u3057\u305f\u96fb\u5b50\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u95a2\u3059\u308b\u304a\u554f\u3044\u5408\u308f\u305b\u306f\u3001\u4e0b\u8a18\u30ea\u30f3\u30af\u5148\u306b\u3042\u308b\u30d5\u30a9\u30fc\u30e0\u3088\u308a\u304a\u9858\u3044\u3057\u307e\u3059\u3002\uff08\u73fe\u5728\u6e96\u5099\u4e2d\uff09<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u200b\u3054\u5229\u7528\u306b\u3042\u305f\u3063\u3066 \u5f53\u30b5\u30a4\u30c8\u306e\u5229\u7528\u898f\u7d04\u306f\u65e5\u672c\u56fd\u306b\u304a\u3051\u308b\u6cd5\u5f8b\u7b49\u5168\u822c\u306b\u6e96\u62e0\u3057\u3001\u305d\u308c\u5f93\u3063\u3066\u89e3\u91c8\u3055\u308c\u307e\u3059\u3002 \u5f53\u30b5\u30a4\u30c8\u306e\u3054\u5229\u7528\u306b\u3088\u3063\u3066\u5229\u7528\u8005\u306f\u5229\u7528\u898f\u7d04\u306b\u540c\u610f\u3057\u305f\u3082\u306e\u3068\u307f\u306a\u3057\u3001\u9055\u53cd\u3057\u305f\u5834\u5408\u306f\u8b66\u5bdf\u30fb\u53f8\u6cd5\u6a5f\u95a2\u7b49\u306e\u5404\u7a2e\u6a5f\u95a2\u3092\u901a\u3057\u3066\u554f\u984c\u3092\u89e3\u2026<\/p>\n","protected":false},"author":1,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"_import_markdown_pro_load_document_selector":0,"_import_markdown_pro_submit_text_textarea":"","footnotes":""},"class_list":["post-134","page","type-page","status-publish","hentry"],"aioseo_notices":[],"_links":{"self":[{"href":"https:\/\/circle.flexi.blue\/wp-json\/wp\/v2\/pages\/134","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/circle.flexi.blue\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/circle.flexi.blue\/wp-json\/wp\/v2\